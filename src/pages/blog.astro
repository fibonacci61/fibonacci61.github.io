---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { postsWithUrls, sortPostsByDate, tagHref, type BlogPost } from "../utils/blog";

let posts = sortPostsByDate(postsWithUrls(await getCollection("blog")));
---

<BaseLayout title="Notes">
    <p>
        Chronological notes about projects, robotics, programming, and anything
        else I keep thinking about.
    </p>
    {
        posts.map((post: BlogPost) => (
            <article class="post-summary">
                <h2>
                    <a href={post.url}>{post.data.title}</a>
                </h2>
                <p class="muted">{post.data.date}</p>
                {
                    (post.data.tags ?? []).length > 0 && (
                        <p class="tag-list">
                            {(post.data.tags ?? []).map((tag) => (
                                <a class="tag" href={tagHref(tag)}>{tag}</a>
                            ))}
                        </p>
                    )
                }
            </article>
        ))
    }
</BaseLayout>
