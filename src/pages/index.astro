---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { notesWithUrls, sortNotesByDate, tagHref } from "../utils/notes";

let notes = sortNotesByDate(notesWithUrls(await getCollection("notes"))).slice(
    0,
    3,
);
---

<BaseLayout title="Home">
    <p>
        I'm Faisal Malallah, formerly known online as Fibonacci. I'm a student
        in Kuwait interested in robotics, systems programming, and computer
        engineering.
    </p>
    <p>
        I use this site for projects, notes, hobbies, and other things I think
        are worth sharing. For the compact version of my technical work, see <a
            href="/projects">projects</a
        >. For the less compact version, read the notes below.
    </p>

    <h2>Featured</h2>
    <ul>
        <li>
            <a href="https://venice.fibn.cc/">Venice</a> - an open-source alternative
            to VEXcode Python.
        </li>
        <li>
            <a href="https://github.com/fibonacci61/yaro">Yaro</a> - a small RISC-V
            operating system experiment.
        </li>
        <li>
            <a href="/notes/vrc_1">VRC Part 1</a> - how I got into robotics.
        </li>
    </ul>

    <h2>Latest Notes</h2>
    <ul class="post-list">
        {
            notes.map((post) => (
                <li>
                    <a href={post.url}>{post.data.title}</a>
                    <span class="muted"> / {post.data.date}</span>
                    {(post.data.tags ?? []).length > 0 && (
                        <span class="tag-list inline-tags">
                            {(post.data.tags ?? []).map((tag) => (
                                <a class="tag" href={tagHref(tag)}>
                                    {tag}
                                </a>
                            ))}
                        </span>
                    )}
                </li>
            ))
        }
    </ul>
</BaseLayout>
