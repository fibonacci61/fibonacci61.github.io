---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
    getAllTags,
    getNotesByTag,
    notesWithUrls,
    sortNotesByDate,
    tagHref,
} from "../../../utils/notes";

export async function getStaticPaths() {
    let notes = notesWithUrls(await getCollection("notes"));

    return getAllTags(notes).map((tag) => ({
        params: { tag },
        props: { tag },
    }));
}

let { tag } = Astro.props;
let posts = sortNotesByDate(
    getNotesByTag(notesWithUrls(await getCollection("notes")), tag),
);
---

<BaseLayout title={`Tag: ${tag}`}>
    <p>
        <a href="/notes">All notes</a>
    </p>

    {
        posts.map((post) => (
            <article class="post-summary">
                <h2>
                    <a href={post.url}>{post.data.title}</a>
                </h2>
                <p class="muted">{post.data.date}</p>
                <p class="tag-list">
                    {(post.data.tags ?? []).map((postTag) => (
                        <a class="tag" href={tagHref(postTag)}>{postTag}</a>
                    ))}
                </p>
            </article>
        ))
    }
</BaseLayout>
