---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
    getAllTags,
    notesWithUrls,
    sortNotesByDate,
    tagHref,
    type Note,
} from "../../utils/notes";

let notes = sortNotesByDate(notesWithUrls(await getCollection("notes")));
let tags = getAllTags(notes);
---

<BaseLayout title="Notes">
    <p>
        Notes about projects, robotics, programming, hobbies, and other things I
        wanted to share.
    </p>

    <div class="filter-row" aria-label="Note filters">
        <span class="filter-label">Filter:</span>
        <ul class="tag-list filter-list">
            {
                tags.map((tag) => (
                    <li><a class="tag" href={tagHref(tag)}>{tag}</a></li>
                ))
            }
        </ul>
    </div>

    {
        notes.map((post: Note) => (
            <article class="post-summary">
                <h2>
                    <a href={post.url}>{post.data.title}</a>
                </h2>
                <p class="muted">{post.data.date}</p>
                {(post.data.tags ?? []).length > 0 && (
                    <p class="tag-list">
                        {(post.data.tags ?? []).map((tag) => (
                            <a class="tag" href={tagHref(tag)}>
                                {tag}
                            </a>
                        ))}
                    </p>
                )}
            </article>
        ))
    }
</BaseLayout>
