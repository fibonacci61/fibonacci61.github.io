---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { tagHref, type Note } from "../../utils/notes";

export async function getStaticPaths() {
    const posts = await getCollection("notes");
    return posts.map((page: any) => ({
        params: { slug: page.slug },
        props: { page },
    }));
}

const { page: anyPage } = Astro.props;
const page: Note = anyPage as Note;

const { Content } = await page.render();
---

<BaseLayout title={`${page.data.title}`}>
    <section>
        <p class="muted">{page.data.date}</p>
        {
            (page.data.tags ?? []).length > 0 && (
                <p class="tag-list">
                    {(page.data.tags ?? []).map((tag) => (
                        <a class="tag" href={tagHref(tag)}>
                            {tag}
                        </a>
                    ))}
                </p>
            )
        }
    </section>
    <Content />
</BaseLayout>
