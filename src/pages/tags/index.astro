---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, notesWithUrls, tagHref } from "../../utils/notes";

let notes = notesWithUrls(await getCollection("notes"));
let tags = getAllTags(notes);
---

<BaseLayout title="Tags">
    <p>
        Tags are lightweight paths through the notes. They are here to connect
        related posts without turning every interest into a permanent section.
    </p>

    <ul class="tag-list block-tags">
        {
            tags.map((tag) => (
                <li><a class="tag" href={tagHref(tag)}>{tag}</a></li>
            ))
        }
    </ul>
</BaseLayout>
